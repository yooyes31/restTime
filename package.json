{
  "name": "resttime",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.playwright\" playwright test",
    "test:e2e:install": "PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.playwright\" playwright install chromium",
    "test:e2e:ui": "PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.playwright\" playwright test --ui"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "element-plus": "^2.9.4",
    "sql.js": "^1.14.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.1.0",
    "vue-tsc": "^2.2.8"
  }
}
